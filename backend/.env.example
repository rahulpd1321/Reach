# Gemini LLM (default) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
LLM_PROVIDER=gemini
# Avoid gemini-2.0-flash on free tier (often quota limit 0)
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACKS=gemini-1.5-flash,gemini-2.5-flash
AUTO_FALLBACK_OPENAI=true

# Optional: OpenAI instead of Gemini
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI embeddings (default: FastEmbed local BGE-small)
USE_OPENAI_EMBEDDINGS=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHROMA_PERSIST_DIR=./data/chroma
FRONTEND_ORIGIN=http://localhost:3000
# Production: https://your-app.vercel.app (comma-separated for multiple)
FRONTEND_ORIGINS=

# Instagram often needs browser cookies (chrome, firefox, edge)
# YTDLP_COOKIES_BROWSER=chrome
